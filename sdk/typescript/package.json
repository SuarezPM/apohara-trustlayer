{
  "name": "@apohara/trustlayer",
  "version": "0.1.0",
  "description": "Apohara TrustLayer TypeScript SDK — HTTP-only client for the TrustLayer control plane. Edge-runtime compatible (Cloudflare Workers, Deno, Bun).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0",
    "zod": "^3.22.0"
  },
  "keywords": [
    "apohara",
    "trustlayer",
    "eu-ai-act",
    "dora",
    "compliance",
    "cose",
    "rfc3161",
    "provenance",
    "evidence"
  ],
  "license": "(MIT OR Apache-2.0)",
  "engines": {
    "node": ">=20"
  }
}
