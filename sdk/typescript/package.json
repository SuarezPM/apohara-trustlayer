{
  "name": "@apohara/trustlayer",
  "version": "0.2.0",
  "description": "Apohara TrustLayer TypeScript SDK — WASM-based offline verification (zero network). Reuses the `tl-wasm` Rust crate (crates/tl-wasm/).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./wasm": "./dist/wasm/index.mjs",
    "./wasm/tl_wasm_bg.wasm": "./dist/wasm/tl_wasm_bg.wasm"
  },
  "files": [
    "dist",
    "wasm",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build ../../crates/tl-wasm --target web --out-dir wasm --release && rm -f wasm/.gitignore && cp -f wasm/* dist/wasm/ 2>/dev/null || true",
    "build:wasm:debug": "wasm-pack build ../../crates/tl-wasm --target web --out-dir wasm --dev",
    "build:ts": "tsup",
    "build:copy": "cp -f wasm/tl_wasm_bg.wasm dist/tl_wasm_bg.wasm",
    "build": "npm run build:wasm && npm run build:ts && npm run build:copy",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "apohara",
    "trustlayer",
    "eu-ai-act",
    "dora",
    "compliance",
    "cose",
    "rfc3161",
    "provenance",
    "evidence",
    "wasm"
  ],
  "license": "(MIT OR Apache-2.0)",
  "engines": {
    "node": ">=20"
  }
}
