# Rust build artifacts
target/
**/target/

# Cargo.lock for libraries (keep for binaries)
# Cargo.lock

# Environment files (NEVER commit secrets)
.env
.env.local
**/.env
**/.env.*

# Node / TS / Python (when applicable)
node_modules/
**/node_modules/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/

# OMC operational state (planning artifacts are ephemeral)
.omc/
**/.omc/

# Reference directory (scaffolding-only repos, not part of the auditor target)
reference/
**/reference/

# Docs directory (internal dev/audit notes; auditor gets the curated ones via README)
docs/
**/docs/

# CLAUDE.md (project-specific assistant context — not part of the auditor target)
CLAUDE.md
**/CLAUDE.md

# IDE / editor
.idea/
*.swp
*.swo
.DS_Store

# GitNexus / index caches
.gitnexus/
.cocoindex/

# Logs and temp files
*.log
*.tmp
.tmp/

# GSD (Get-Shit-Done) operational state
.gsd/

# bg-shell (background shell state from prior sessions)
.bg-shell/

# OMO (oh-my-opencode) runtime artifacts (continuation state, run queues)
.omo/
**/.omo/

# SQLite databases (test artifacts; the schema lives in migrations/)
*.db
*.sqlite
*.sqlite3
**/*.db
**/*.sqlite
**/*.sqlite3

# NotaryService + control plane test artifacts (PDF certificates, SQLite DBs,
# generated disclosures). Production usage writes to PG via Alembic; these
# are the dev/test scratch space and should never be committed.
artifacts/
**/artifacts/
services/control_plane/oasb_runtime/

# SQLite transient files (notary.db-wal, .db-shm from WAL mode)
notary.db-shm
notary.db-wal

# WASM binaries (regenerated by `wasm-pack build` via `npm run build:wasm`).
# Tracking the regenerated binary bloats the repo and trips OpenSSF
# Scorecard's Binary-Artifacts check. Source artifacts (.d.ts, .js) are
# still tracked.
sdk/typescript/wasm/*.wasm
