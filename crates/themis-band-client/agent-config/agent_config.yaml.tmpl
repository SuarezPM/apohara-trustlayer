# Apohara Themis — Band agent configuration template
# ---------------------------------------------------
# This file is consumed by `themis-band-client` (subprocess wrapper around the
# official `band-sdk[langgraph]`). It is a TEMPLATE — actual values come from
# environment variables loaded via `source ~/.config/apohara/secrets.env`.
#
# NEVER commit the rendered file with real values. The renderer strips secrets.
#
# Mapping (9 native Band agents, registered + keys regenerated by Pablo 2026-06-12):
#   1. themis-orchestrator  → coordinates the workflow, creates sub-rooms
#   2. extractor            → multimodal PDF → structured JSON (AI/ML API)
#   3. po-matcher           → invoice vs PO database (Featherless Qwen3-Coder-30B)
#   4. fraud-auditor        → multimodal fraud detection (AI/ML API, emits HALT)
#   5. gaap-classifier      → expense categorization (AI/ML API)
#   6. provenance-signer    → Ed25519 + BLAKE3 + RFC 3161 (no LLM)
#   7. audit-watchdog       → shadow, pre-BAAAR coherence alerts
#   8. regression-tester    → shadow, re-runs BLAKE3 chain verification
#   9. demo-narrator        → shadow, judge-friendly prose for the live UI
#
# To render this template: `uv run scripts/render_agent_config.py`

themis-orchestrator:
  handle: "@apohara-themis/themis-orchestrator"
  agent_id: "${BAND_AGENT_ORCHESTRATOR_ID}"
  api_key: "${BAND_AGENT_ORCHESTRATOR_API_KEY}"
  role: orchestrator
  framework: "band-sdk[langgraph]"
  spawns_subprocess: true

extractor:
  handle: "@apohara-themis/extractor"
  agent_id: "${BAND_AGENT_EXTRACTOR_ID}"
  api_key: "${BAND_AGENT_EXTRACTOR_API_KEY}"
  role: worker
  framework: "band-sdk[langgraph]"
  llm_backend: aimlapi
  llm_model: "claude-fable-5"
  multimodal: true
  spawns_subprocess: true

po-matcher:
  handle: "@apohara-themis/po-matcher"
  agent_id: "${BAND_AGENT_PO_MATCHER_ID}"
  api_key: "${BAND_AGENT_PO_MATCHER_API_KEY}"
  role: worker
  framework: "band-sdk[langgraph]"
  llm_backend: featherless
  llm_model: "qwen3-coder-30b"
  spawns_subprocess: true

fraud-auditor:
  handle: "@apohara-themis/fraud-auditor"
  agent_id: "${BAND_AGENT_FRAUD_AUDITOR_ID}"
  api_key: "${BAND_AGENT_FRAUD_AUDITOR_API_KEY}"
  role: worker
  framework: "band-sdk[langgraph]"
  llm_backend: aimlapi
  llm_model: "claude-fable-5"
  multimodal: true
  emits_halt: true
  spawns_subprocess: true

gaap-classifier:
  handle: "@apohara-themis/gaap-classifier"
  agent_id: "${BAND_AGENT_GAAP_CLASSIFIER_ID}"
  api_key: "${BAND_AGENT_GAAP_CLASSIFIER_API_KEY}"
  role: worker
  framework: "band-sdk[langgraph]"
  llm_backend: aimlapi
  llm_model: "claude-fable-5"
  spawns_subprocess: true

provenance-signer:
  handle: "@apohara-themis/provenance-signer"
  agent_id: "${BAND_AGENT_PROVENANCE_SIGNER_ID}"
  api_key: "${BAND_AGENT_PROVENANCE_SIGNER_API_KEY}"
  role: worker
  framework: "band-sdk[langgraph]"
  llm_backend: none
  crypto: ["ed25519", "blake3", "rfc3161"]
  spawns_subprocess: true

audit-watchdog:
  handle: "@apohara-themis/audit-watchdog"
  agent_id: "${BAND_AGENT_AUDIT_WATCHDOG_ID}"
  api_key: "${BAND_AGENT_AUDIT_WATCHDOG_API_KEY}"
  role: shadow
  framework: "band-sdk[langgraph]"
  llm_backend: none
  spawns_subprocess: true

regression-tester:
  handle: "@apohara-themis/regression-tester"
  agent_id: "${BAND_AGENT_REGRESSION_TESTER_ID}"
  api_key: "${BAND_AGENT_REGRESSION_TESTER_API_KEY}"
  role: shadow
  framework: "band-sdk[langgraph]"
  llm_backend: none
  crypto: ["blake3"]
  spawns_subprocess: true

demo-narrator:
  handle: "@apohara-themis/demo-narrator"
  agent_id: "${BAND_AGENT_DEMO_NARRATOR_ID}"
  api_key: "${BAND_AGENT_DEMO_NARRATOR_API_KEY}"
  role: shadow
  framework: "band-sdk[langgraph]"
  llm_backend: aimlapi
  llm_model: "claude-fable-5"
  spawns_subprocess: true

# 2 parent rooms (1 per tenant). Created by themis-bootstrap.py on first run.
tenants:
  - id: "${THEMIS_TENANT_STARK_ID}"
    name: "${THEMIS_TENANT_STARK_NAME}"
  - id: "${THEMIS_TENANT_WAYNE_ID}"
    name: "${THEMIS_TENANT_WAYNE_NAME}"
